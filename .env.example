# Copiez ce fichier en ".env" et remplissez les valeurs depuis
# la console Firebase (Paramètres du projet > Vos applications > SDK Config).
# Tant que ce fichier n'existe pas (ou que VITE_FIREBASE_API_KEY est vide),
# l'application utilise automatiquement les données statiques de src/data/.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
